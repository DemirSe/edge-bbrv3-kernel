# Edge VPS required core
CONFIG_MODULES=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# KVM / virtio / disk / rootfs
CONFIG_KVM_GUEST=y
CONFIG_PCI=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_NET=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_VIRTIO=y
CONFIG_XFS_FS=y

# Networking required by sing-box server
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_CT=y
CONFIG_NFT_REJECT=y
CONFIG_NFT_REJECT_INET=y

# BBRv3 / fq target
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_FQ_CODEL=y

# CPU crypto/hash acceleration useful on EPYC/KVM
CONFIG_CRYPTO_AES_NI_INTEL=y
CONFIG_CRYPTO_GHASH_CLMUL_NI_INTEL=y
CONFIG_CRYPTO_CRC32C_INTEL=y
CONFIG_CRYPTO_SHA256_SSSE3=y
CONFIG_CRYPTO_SHA512_SSSE3=y

# Remove server-irrelevant surfaces
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set
# CONFIG_BT is not set
# CONFIG_SOUND is not set
# CONFIG_SND is not set
# CONFIG_FLOPPY is not set
# CONFIG_VMWARE_VMCI is not set
# CONFIG_VSOCKETS is not set
# CONFIG_VIRTIO_VSOCKETS is not set
# CONFIG_ISO9660_FS is not set
# CONFIG_UDF_FS is not set
# CONFIG_BLK_DEV_SR is not set

# No debug-symbol bloat
# CONFIG_DEBUG_INFO is not set
# CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT is not set
# CONFIG_GDB_SCRIPTS is not set
# CONFIG_KGDB is not set
