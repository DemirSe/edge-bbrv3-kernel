# Edge VPS strict required core
CONFIG_MODULES=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# KVM / virtio / root disk
CONFIG_KVM_GUEST=y
CONFIG_PCI=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_NET=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_VIRTIO=y
CONFIG_XFS_FS=y

# Minimal networking for sing-box server
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NFT_CT=y

# BBRv3 / fq target
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_NET_SCH_FQ=y

# Useful CPU crypto/hash acceleration
CONFIG_CRYPTO_AES_NI_INTEL=y
CONFIG_CRYPTO_GHASH_CLMUL_NI_INTEL=y
CONFIG_CRYPTO_CRC32C_INTEL=y
CONFIG_CRYPTO_SHA256_SSSE3=y
CONFIG_CRYPTO_SHA512_SSSE3=y

# Strip non-server surfaces
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set
# CONFIG_CFG80211 is not set
# CONFIG_MAC80211 is not set
# CONFIG_BT is not set
# CONFIG_SOUND is not set
# CONFIG_SND is not set
# CONFIG_DRM is not set
# CONFIG_DRM_BOCHS is not set
# CONFIG_USB is not set
# CONFIG_USB_SUPPORT is not set
# CONFIG_FLOPPY is not set
# CONFIG_ATA is not set
# CONFIG_ATA_PIIX is not set
# CONFIG_ATA_GENERIC is not set
# CONFIG_CDROM is not set
# CONFIG_BLK_DEV_SR is not set
# CONFIG_ISO9660_FS is not set
# CONFIG_UDF_FS is not set
# CONFIG_VMWARE_VMCI is not set
# CONFIG_VSOCKETS is not set
# CONFIG_VIRTIO_VSOCKETS is not set
# CONFIG_TUN is not set
# CONFIG_IPV6_SIT is not set
# CONFIG_IPV6_GRE is not set
# CONFIG_IPV6_TUNNEL is not set
# CONFIG_IPV6_VTI is not set

# Native nftables only; no legacy iptables/xtables compatibility
# CONFIG_NFT_COMPAT is not set
# CONFIG_NETFILTER_XTABLES is not set
# CONFIG_NETFILTER_XTABLES_COMPAT is not set
# CONFIG_IP_NF_IPTABLES is not set
# CONFIG_IP_NF_FILTER is not set
# CONFIG_IP_NF_MANGLE is not set
# CONFIG_IP_NF_NAT is not set
# CONFIG_IP6_NF_IPTABLES is not set
# CONFIG_IP6_NF_FILTER is not set
# CONFIG_IP6_NF_MANGLE is not set
# CONFIG_ARP_TABLES is not set

# No debug-symbol bloat
# CONFIG_DEBUG_INFO is not set
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_GDB_SCRIPTS is not set
# CONFIG_KGDB is not set
